{
  "name": "taskflow",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm -w packages/backend run dev",
    "dev:frontend": "npm -w packages/frontend run dev",
    "build": "npm -w packages/shared run build && npm -w packages/backend run build && npm -w packages/frontend run build",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "db:generate": "npm -w packages/backend run db:generate",
    "db:migrate": "npm -w packages/backend run db:migrate",
    "db:studio": "npm -w packages/backend run db:studio",
    "db:seed": "npm -w packages/backend run db:seed",
    "test": "npm -w packages/backend run test && npm -w packages/frontend run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
